{
  "_comment": "NobroRTOS multi-board collection manifest. Each board declares a transport (how to reach it) and a protocol (how to read it). New boards/apps plug in by adding an entry - no code change. 'optional' boards never fail the run when absent/silent.",
  "boards": [
    {
      "name": "board1",
      "kind": "nRF52840 / NobroRTOS / MPU-9250 (SPI)",
      "transport": "jlink",
      "device": "nRF52840_xxAA",
      "protocol": "nobro_report",
      "addr": "0x20000038",
      "schema": "spi_imu",
      "arch": "cortex-m4f/nrf52840"
    },
    {
      "name": "esp32c3",
      "kind": "INA3221 power monitor (third-party ina3221 app)",
      "transport": "serial",
      "port": "COM20",
      "baud": 115200,
      "protocol": "jsonl_bridge",
      "reset_on_open": false,
      "optional": true,
      "note": "AWAITING-REPLUG 2026-07-02: C3 USB-Serial-JTAG attaches in ROM/download mode but not in app mode - a latched device state that survived reflash/erase/pullup-toggle/elevated-restart. Physical USB replug required; INA app (CDC build) is resident and will serve JSONL immediately after. Then remove 'optional'.",
      "arch": "riscv32imc/esp32c3"
    },
    {
      "name": "nano",
      "kind": "Arduino Nano + MPU6050 SY-104 (ICM-clone die, WHO_AM_I=0x98)",
      "transport": "serial",
      "port": "COM24",
      "baud": 115200,
      "protocol": "serial_regex",
      "match": "MPU6050 who=0x\\S+ .*mag=\\d+mg",
      "reset_on_open": true,
      "note": "Real IMU reconnected 2026-07-02; clone Nano needs the old-bootloader upload (arduino:avr:nano:cpu=atmega328old).",
      "arch": "avr/atmega328"
    },
    {
      "name": "sim_relay",
      "kind": "simulated relay + temperature node",
      "protocol": "sim",
      "sim_kind": "temp",
      "seed": 10,
      "route": [
        "collector"
      ],
      "arch": "sim"
    },
    {
      "name": "sim_power_a",
      "kind": "simulated power node (2-hop via relay)",
      "protocol": "sim",
      "sim_kind": "power",
      "seed": 11,
      "route": [
        "sim_relay",
        "collector"
      ],
      "arch": "sim"
    },
    {
      "name": "sim_imu_b",
      "kind": "simulated IMU node (2-hop via relay)",
      "protocol": "sim",
      "sim_kind": "imu",
      "seed": 12,
      "route": [
        "sim_relay",
        "collector"
      ],
      "arch": "sim"
    },
    {
      "name": "sim_power_c",
      "kind": "simulated power node (lossy 3-hop edge)",
      "protocol": "sim",
      "sim_kind": "power",
      "seed": 13,
      "route": [
        "sim_imu_b",
        "sim_relay",
        "collector"
      ],
      "loss": 0.3,
      "optional": true,
      "arch": "sim"
    },
    {
      "name": "uno_r4",
      "kind": "Arduino UNO R4 WiFi",
      "transport": "serial",
      "port": "COM23",
      "baud": 115200,
      "protocol": "serial_regex",
      "match": ".+",
      "reset_on_open": true,
      "optional": true,
      "seconds": 2,
      "arch": "cortex-m4/ra4m1"
    },
    {
      "name": "xiao_vision",
      "kind": "XIAO ESP32S3 Sense camera (OV3660, NiusCam frame dump)",
      "transport": "serial",
      "port": "COM27",
      "protocol": "vision",
      "seconds": 60,
      "tool_python": "H:/miniconda/envs/IronEngineWorld/python.exe",
      "arch": "xtensa-lx7/esp32s3"
    },
    {
      "name": "pico2",
      "kind": "Pico 2 W / RP2350 (NobroRTOS portable-core port)",
      "transport": "serial",
      "port": "COM29",
      "baud": 115200,
      "protocol": "serial_regex",
      "match": "NOBRO-RP2350 arch=\\S+ subsystems=\\d+ all_pass=1",
      "seconds": 3,
      "note": "self-DFU: send 'DFU' on the port and the UF2 drive re-mounts in ~1 s",
      "arch": "cortex-m33/rp2350"
    },
    {
      "name": "s3cam_vision",
      "kind": "ESP32-S3-CAM (new OV5640 66deg, NiusCam frame dump)",
      "transport": "serial",
      "port": "COM25",
      "protocol": "vision",
      "seconds": 60,
      "tool_python": "H:/miniconda/envs/IronEngineWorld/python.exe",
      "arch": "xtensa-lx7/esp32s3"
    },
    {
      "name": "aithinker_vision",
      "kind": "ESP32-CAM AI-Thinker (OV2640 66deg, NiusCam frame dump)",
      "transport": "serial",
      "port": "COM26",
      "protocol": "vision",
      "seconds": 60,
      "tool_python": "H:/miniconda/envs/IronEngineWorld/python.exe",
      "arch": "xtensa-lx6/esp32"
    },
    {
      "name": "audio",
      "kind": "ESP32-S3 UNO + ES8311 codec (4-class sound events)",
      "transport": "serial",
      "port": "COM28",
      "baud": 115200,
      "protocol": "serial_regex",
      "match": "NOBRO-AUDIO node=es8311 classes=\\d+ ready=1",
      "reset_on_open": false,
      "seconds": 4,
      "arch": "xtensa-lx7/esp32s3"
    }
  ],
  "schemas": {
    "spi_imu": {
      "magic": "0x4E425350",
      "words": 9,
      "fields": [
        "magic",
        "version",
        "completed",
        "all_pass",
        "who_am_i",
        "accel_mg",
        "reads",
        "errors",
        "checksum"
      ],
      "pass_field": "all_pass"
    },
    "selftest": {
      "magic": "0x4E425354",
      "words": 21,
      "fields": [
        "magic",
        "version",
        "completed",
        "all_pass"
      ],
      "pass_field": "all_pass"
    },
    "radio": {
      "magic": "0x4E524144",
      "words": 8,
      "fields": [
        "magic",
        "version",
        "role",
        "tx_sent",
        "rx_received",
        "last_seq",
        "all_pass",
        "checksum"
      ],
      "pass_field": "all_pass"
    }
  }
}