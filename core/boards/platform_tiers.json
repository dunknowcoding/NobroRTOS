{
  "schema": "nobro-platform-support-v1",
  "providers": [
    "timebase",
    "deadline",
    "event_capture",
    "servo_pwm",
    "i2c",
    "spi",
    "usb",
    "lease"
  ],
  "tiers": {
    "deep": "portable contracts plus board-specific peripheral providers",
    "provider": "one or more portable provider traits implemented for the target",
    "core": "target startup and status path available; portable peripheral providers are incomplete",
    "absent": "no maintained target integration"
  },
  "platforms": {
    "nrf52840": {
      "arch": "thumbv7em",
      "tier": "deep",
      "implements": [
        "timebase",
        "deadline",
        "event_capture",
        "servo_pwm",
        "i2c",
        "spi",
        "lease"
      ]
    },
    "rp2350": {
      "arch": "thumbv8m",
      "tier": "provider",
      "implements": ["timebase"]
    },
    "esp32c3": {
      "arch": "riscv32imc",
      "tier": "provider",
      "implements": ["timebase"],
      "limitations": "event routing and PWM use target-specific peripherals"
    },
    "esp32s3": {
      "arch": "xtensa",
      "tier": "provider",
      "implements": [
        "timebase",
        "deadline",
        "servo_pwm",
        "i2c",
        "spi",
        "usb"
      ]
    },
    "ra4m1": {
      "arch": "thumbv7em",
      "tier": "core",
      "implements": []
    },
    "samd21": {
      "arch": "thumbv6m",
      "tier": "core",
      "implements": []
    },
    "avr_nano": {
      "arch": "avr",
      "tier": "core",
      "implements": []
    }
  }
}
