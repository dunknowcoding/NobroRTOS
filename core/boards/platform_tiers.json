{
  "schema": "nobro-platform-support-v2",
  "feature_registry": "core/boards/feature_providers.json",
  "reference_platform": "nrf52840",
  "providers": [
    "timebase",
    "deadline",
    "event_capture",
    "dma_completion",
    "servo_pwm",
    "i2c",
    "spi",
    "usb",
    "lease"
  ],
  "facade_offers": [
    "clock",
    "deadline",
    "adc",
    "pwm",
    "i2c",
    "spi",
    "byte_io"
  ],
  "tiers": {
    "deep": "one native composition implements every currently declared provider capability",
    "provider": "one or more portable provider traits implemented for the target",
    "core": "target startup and status path available; portable peripheral providers are incomplete",
    "absent": "no maintained target integration"
  },
  "evidence_kinds": {
    "host-test": "executable host-side contract or state-machine test",
    "target-build": "successful compilation for the declared target; not physical behavior"
  },
  "maturities": {
    "implemented": "the declared surface is present and has the cited non-physical evidence",
    "experimental": "the declared surface is usable but may change incompatibly"
  },
  "runners": {
    "rust-matrix": {
      "workflow_job": "rust-matrix",
      "receipt_driver": ".github/workflows/gates.yml"
    },
    "cross-mcu": {
      "workflow_job": "cross-mcu",
      "receipt_driver": "tools/ci_matrix.sh"
    },
    "arduino-package": {
      "workflow_job": "arduino-package",
      "receipt_driver": ".github/workflows/gates.yml"
    },
    "arduino-nrf-package": {
      "workflow_job": "arduino-nrf-package",
      "receipt_driver": ".github/workflows/gates.yml"
    }
  },
  "evidence_gates": {
    "nrf52840-hal-host": {
      "kind": "host-test",
      "runner": "rust-matrix",
      "required": true,
      "cwd": "core",
      "command": [
        "cargo",
        "test",
        "--target",
        "{host_target}",
        "--locked",
        "-p",
        "nobro-hal"
      ],
      "claim_scopes": [
        {
          "platform": "nrf52840",
          "composition": "native",
          "capabilities": ["timebase", "deadline", "event_capture", "dma_completion", "servo_pwm", "i2c", "spi", "lease"]
        }
      ]
    },
    "nrf52840-target-build": {
      "kind": "target-build",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core",
      "command": [
        "cargo",
        "build",
        "-p",
        "nobro-hal",
        "--no-default-features",
        "--features",
        "board-promicro-nosd,nrf-twim-async",
        "--target",
        "thumbv7em-none-eabihf",
        "--locked"
      ],
      "claim_scopes": [
        {
          "platform": "nrf52840",
          "composition": "native",
          "capabilities": ["timebase", "deadline", "event_capture", "dma_completion", "servo_pwm", "i2c", "spi", "lease"]
        }
      ]
    },
    "nrf52840-usb-host": {
      "kind": "host-test",
      "runner": "rust-matrix",
      "required": true,
      "cwd": "core",
      "command": [
        "cargo",
        "test",
        "--locked",
        "-p",
        "nobro-usb",
        "-p",
        "nrf-usbd",
        "--target",
        "{host_target}"
      ],
      "claim_scopes": [
        {
          "platform": "nrf52840",
          "composition": "native",
          "capabilities": ["usb"]
        }
      ]
    },
    "nrf52840-usb-target-build": {
      "kind": "target-build",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core",
      "command": [
        "cargo",
        "check",
        "--locked",
        "-p",
        "usb-stack-demo",
        "--target",
        "thumbv7em-none-eabihf"
      ],
      "claim_scopes": [
        {
          "platform": "nrf52840",
          "composition": "native",
          "capabilities": ["usb"]
        }
      ]
    },
    "rp2350-target-build": {
      "kind": "target-build",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core/ports/rp2350",
      "command": ["cargo", "build", "--locked", "--release"],
      "claim_scopes": [
        {
          "platform": "rp2350",
          "composition": "native",
          "capabilities": ["timebase"]
        }
      ]
    },
    "rp2350-dma-target-build": {
      "kind": "target-build",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core/ports/rp2350",
      "command": ["cargo", "build", "--locked", "--release", "--features", "dma-completion"],
      "claim_scopes": [
        {
          "platform": "rp2350",
          "composition": "native",
          "capabilities": ["dma_completion"]
        }
      ]
    },
    "esp32c3-target-build": {
      "kind": "target-build",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core/ports/esp32c3",
      "command": ["cargo", "build", "--locked", "--release", "--bins"],
      "claim_scopes": [
        {
          "platform": "esp32c3",
          "composition": "native",
          "capabilities": ["timebase", "usb"]
        }
      ]
    },
    "esp32c3-usb-host": {
      "kind": "host-test",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core",
      "command": [
        "cargo",
        "test",
        "-p",
        "nobro-usb",
        "--no-default-features",
        "--features",
        "backend-usb-serial-jtag-esp32c3",
        "--target",
        "{host_target}",
        "--locked"
      ],
      "claim_scopes": [
        {
          "platform": "esp32c3",
          "composition": "native",
          "capabilities": ["usb"]
        }
      ]
    },
    "esp32-arduino-peripheral-target-build": {
      "kind": "target-build",
      "runner": "arduino-package",
      "required": true,
      "cwd": ".",
      "command": ["python", "tools/check_esp32_peripheral_integrations.py"],
      "claim_scopes": [
        {
          "platform": "esp32c3",
          "composition": "arduino",
          "capabilities": ["adc_dma"]
        },
        {
          "platform": "esp32p4",
          "composition": "arduino",
          "capabilities": ["adc_dma"]
        },
        {
          "platform": "esp32s3",
          "composition": "arduino",
          "capabilities": ["adc_dma"]
        }
      ]
    },
    "esp32s3-arduino-audio-target-build": {
      "kind": "target-build",
      "runner": "arduino-package",
      "required": true,
      "cwd": ".",
      "command": [
        "python",
        "tools/check_audio_integrations.py",
        "--library",
        "_work/NiusAudio",
        "--compile"
      ],
      "claim_scopes": [
        {
          "platform": "esp32s3",
          "composition": "arduino",
          "capabilities": ["audio_i2s"]
        }
      ]
    },
    "esp32s3-target-build": {
      "kind": "target-build",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core/ports/esp32s3",
      "command": ["cargo", "+esp", "build", "--locked", "--release"],
      "claim_scopes": [
        {
          "platform": "esp32s3",
          "composition": "native",
          "capabilities": ["timebase", "deadline", "servo_pwm", "i2c", "spi", "usb"]
        }
      ]
    },
    "esp32s3-usb-host": {
      "kind": "host-test",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core",
      "command": [
        "cargo",
        "test",
        "-p",
        "nobro-usb",
        "--no-default-features",
        "--features",
        "backend-usb-serial-jtag-esp32s3",
        "--target",
        "{host_target}",
        "--locked"
      ],
      "claim_scopes": [
        {
          "platform": "esp32s3",
          "composition": "native",
          "capabilities": ["usb"]
        }
      ]
    },
    "ra4m1-provider-host": {
      "kind": "host-test",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core/ports/ra4m1",
      "command": ["cargo", "test", "--locked", "--lib", "--target", "{host_target}"],
      "claim_scopes": [
        {
          "platform": "ra4m1",
          "composition": "native",
          "capabilities": ["timebase", "deadline", "dma_completion", "usb"]
        }
      ]
    },
    "ra4m1-usb-host": {
      "kind": "host-test",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core",
      "command": [
        "cargo",
        "test",
        "-p",
        "nobro-usb",
        "--no-default-features",
        "--features",
        "backend-ra-usbfs",
        "--target",
        "{host_target}",
        "--locked"
      ],
      "claim_scopes": [
        {
          "platform": "ra4m1",
          "composition": "native",
          "capabilities": ["usb"]
        }
      ]
    },
    "ra4m1-target-build": {
      "kind": "target-build",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core/ports/ra4m1",
      "command": ["cargo", "build", "--locked", "--release"],
      "claim_scopes": [
        {
          "platform": "ra4m1",
          "composition": "native",
          "capabilities": ["timebase", "deadline", "usb"]
        }
      ]
    },
    "ra4m1-event-dma-target-build": {
      "kind": "target-build",
      "runner": "cross-mcu",
      "required": true,
      "cwd": "core/ports/ra4m1",
      "command": ["cargo", "build", "--locked", "--release", "--features", "event-dma-selftest"],
      "claim_scopes": [
        {
          "platform": "ra4m1",
          "composition": "native",
          "capabilities": ["dma_completion"]
        }
      ]
    },
    "arduino-facade-contract": {
      "kind": "host-test",
      "runner": "arduino-package",
      "required": true,
      "cwd": ".",
      "command": ["python", "tools/check_arduino_facade.py"],
      "claim_scopes": [
        {
          "platform": "ra4m1",
          "composition": "arduino",
          "capabilities": ["clock", "deadline", "adc", "pwm", "i2c", "spi", "byte_io"]
        },
        {
          "platform": "nrf52840",
          "composition": "arduino",
          "capabilities": ["clock", "deadline", "adc", "pwm", "i2c", "spi", "byte_io"]
        }
      ]
    },
    "arduino-ra4m1-compile": {
      "kind": "target-build",
      "runner": "arduino-package",
      "required": true,
      "cwd": ".",
      "command": ["python", "tools/check_arduino_compile.py"],
      "environment": {
        "NOBRO_ARDUINO_FQBNS": "arduino:avr:uno,arduino:renesas_uno:unor4wifi,esp32:esp32:esp32s3"
      },
      "claim_scopes": [
        {
          "platform": "ra4m1",
          "composition": "arduino",
          "capabilities": ["clock", "deadline", "adc", "pwm", "i2c", "spi", "byte_io"]
        }
      ]
    },
    "arduino-wifis3-target-build": {
      "kind": "target-build",
      "runner": "arduino-package",
      "required": true,
      "cwd": ".",
      "command": ["python", "tools/check_wifis3_integrations.py"],
      "claim_scopes": [
        {
          "platform": "ra4m1",
          "composition": "arduino",
          "capabilities": ["wifi_link"]
        }
      ]
    },
    "arduino-ble-unor4-target-build": {
      "kind": "target-build",
      "runner": "arduino-package",
      "required": true,
      "cwd": ".",
      "command": ["python", "tools/check_arduino_ble_integrations.py"],
      "claim_scopes": [
        {
          "platform": "ra4m1",
          "composition": "arduino",
          "capabilities": ["ble_link"]
        }
      ]
    },
    "arduino-esp-wifi-target-build": {
      "kind": "target-build",
      "runner": "arduino-package",
      "required": true,
      "cwd": ".",
      "command": ["python", "tools/check_arduino_esp_wifi.py"],
      "claim_scopes": [
        {
          "platform": "esp32c3",
          "composition": "arduino",
          "capabilities": ["wifi_link"]
        }
      ]
    },
    "arduino-nrf52840-compile": {
      "kind": "target-build",
      "runner": "arduino-nrf-package",
      "required": true,
      "cwd": ".",
      "command": ["python", "tools/check_arduino_compile.py"],
      "environment": {
        "NOBRO_ARDUINO_FQBNS": "arduinonrf:nrf52:promicro_nrf52840:usbcdc=enabled"
      },
      "claim_scopes": [
        {
          "platform": "nrf52840",
          "composition": "arduino",
          "capabilities": ["clock", "deadline", "adc", "pwm", "i2c", "spi", "byte_io"]
        }
      ]
    }
  },
  "platforms": {
    "nrf52840": {
      "arch": "thumbv7em",
      "tier": "deep",
      "implementation_root": "core/crates/nobro_hal/src/platform/nrf52840",
      "compositions": {
        "native": {
          "surface": "native",
          "claims": {
            "timebase": {"maturity": "implemented", "evidence": ["nrf52840-hal-host", "nrf52840-target-build"]},
            "deadline": {"maturity": "implemented", "evidence": ["nrf52840-hal-host", "nrf52840-target-build"]},
            "event_capture": {"maturity": "implemented", "evidence": ["nrf52840-hal-host", "nrf52840-target-build"]},
            "dma_completion": {"maturity": "implemented", "evidence": ["nrf52840-hal-host", "nrf52840-target-build"]},
            "servo_pwm": {"maturity": "implemented", "evidence": ["nrf52840-hal-host", "nrf52840-target-build"]},
            "i2c": {"maturity": "implemented", "evidence": ["nrf52840-hal-host", "nrf52840-target-build"]},
            "spi": {"maturity": "implemented", "evidence": ["nrf52840-hal-host", "nrf52840-target-build"]},
            "usb": {"maturity": "implemented", "evidence": ["nrf52840-usb-host", "nrf52840-usb-target-build"]},
            "lease": {"maturity": "implemented", "evidence": ["nrf52840-hal-host", "nrf52840-target-build"]}
          }
        },
        "arduino": {
          "surface": "arduino",
          "claims": {
            "clock": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-nrf52840-compile"]},
            "deadline": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-nrf52840-compile"]},
            "adc": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-nrf52840-compile"]},
            "pwm": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-nrf52840-compile"]},
            "i2c": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-nrf52840-compile"]},
            "spi": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-nrf52840-compile"]},
            "byte_io": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-nrf52840-compile"]}
          }
        }
      }
    },
    "rp2350": {
      "arch": "thumbv8m",
      "tier": "provider",
      "implementation_root": "core/ports/rp2350",
      "limitations": "the target build proves compilation only; physical timebase and DMA completion/cancellation behavior remain outside this public matrix",
      "compositions": {
        "native": {
          "surface": "native",
          "claims": {
            "timebase": {"maturity": "implemented", "evidence": ["rp2350-target-build"]},
            "dma_completion": {"maturity": "experimental", "evidence": ["rp2350-dma-target-build"]}
          }
        }
      }
    },
    "esp32c3": {
      "arch": "riscv32imc",
      "tier": "provider",
      "implementation_root": "core/ports/esp32c3",
      "limitations": "timebase evidence is target compilation only; USB Serial/JTAG has host state-machine coverage and a target build, while physical recovery remains pending",
      "compositions": {
        "native": {
          "surface": "native",
          "claims": {
            "timebase": {"maturity": "implemented", "evidence": ["esp32c3-target-build"]},
            "usb": {"maturity": "implemented", "evidence": ["esp32c3-usb-host", "esp32c3-target-build"]}
          }
        },
        "arduino": {
          "surface": "arduino",
          "claims": {
            "adc_dma": {
              "maturity": "experimental",
              "evidence": ["esp32-arduino-peripheral-target-build"],
              "limitations": "The exact persistent-buffer binding is configuration-specific; calibrated accuracy remains unverified."
            },
            "wifi_link": {
              "maturity": "implemented",
              "evidence": ["arduino-esp-wifi-target-build"],
              "limitations": "One exact pinned Arduino-ESP32 C3 station composition is configuration-priced at four HTTP transactions per second and has state-restoring association/DNS/TCP/lifecycle evidence. Other workloads, boards, and WiFi/BLE coexistence remain unverified."
            }
          }
        }
      }
    },
    "esp32p4": {
      "arch": "riscv32imafc",
      "tier": "core",
      "implementation_root": "packages/arduino",
      "limitations": "Only the configuration-specific Arduino persistent ADC-DMA composition is claimed; no native Rust provider tier is inferred.",
      "compositions": {
        "arduino": {
          "surface": "arduino",
          "claims": {
            "adc_dma": {
              "maturity": "experimental",
              "evidence": ["esp32-arduino-peripheral-target-build"],
              "limitations": "The exact binding uses a DMA-aligned 32-conversion frame; calibrated accuracy remains unverified."
            }
          }
        }
      }
    },
    "esp32s3": {
      "arch": "xtensa",
      "tier": "provider",
      "implementation_root": "core/ports/esp32s3",
      "limitations": "Native Xtensa and USB claims remain build/host-test scoped. The separate Arduino composition has exact, configuration-specific persistent ADC and full-duplex audio bindings; it does not promote native providers, other ADC shapes, codecs, or rates.",
      "compositions": {
        "native": {
          "surface": "native",
          "claims": {
            "timebase": {"maturity": "experimental", "evidence": ["esp32s3-target-build"]},
            "deadline": {"maturity": "experimental", "evidence": ["esp32s3-target-build"]},
            "servo_pwm": {"maturity": "experimental", "evidence": ["esp32s3-target-build"]},
            "i2c": {"maturity": "experimental", "evidence": ["esp32s3-target-build"]},
            "spi": {"maturity": "experimental", "evidence": ["esp32s3-target-build"]},
            "usb": {"maturity": "implemented", "evidence": ["esp32s3-usb-host", "esp32s3-target-build"]}
          }
        },
        "arduino": {
          "surface": "arduino",
          "claims": {
            "adc_dma": {
              "maturity": "experimental",
              "evidence": ["esp32-arduino-peripheral-target-build"],
              "limitations": "Exact only for one ADC1 channel, 12-bit calibrated output, 16 conversions per frame, 20 ksample/s, and 1250 reads per second. Absolute input accuracy remains unverified."
            },
            "audio_i2s": {
              "maturity": "experimental",
              "evidence": ["esp32s3-arduino-audio-target-build"],
              "limitations": "Exact only for 16 kHz mono signed-16 full-duplex ES8311 audio with 192-byte frames, two queue slots, and 100 transfers per second."
            }
          }
        }
      }
    },
    "ra4m1": {
      "arch": "thumbv7em",
      "tier": "provider",
      "implementation_root": "core/ports/ra4m1",
      "limitations": "native Rust provides timebase/deadline/USB plus an opt-in GPT/ELC/DMAC completion future; the DMA provider owns GPT0/GPT1, DMAC0, DELSR0, and ICU/NVIC slots 30-31 while active; host state/contract tests and a target build do not establish physical native-USB enumeration; DWT time must be sampled during active execution within each approximately 89-second wrap and SysTick one-shots are limited to approximately 349 milliseconds",
      "compositions": {
        "native": {
          "surface": "native",
          "claims": {
            "timebase": {"maturity": "implemented", "evidence": ["ra4m1-provider-host", "ra4m1-target-build"]},
            "deadline": {"maturity": "implemented", "evidence": ["ra4m1-provider-host", "ra4m1-target-build"]},
            "dma_completion": {"maturity": "experimental", "evidence": ["ra4m1-provider-host", "ra4m1-event-dma-target-build"]},
            "usb": {"maturity": "implemented", "evidence": ["ra4m1-provider-host", "ra4m1-usb-host", "ra4m1-target-build"]}
          }
        },
        "arduino": {
          "surface": "arduino",
          "claims": {
            "clock": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-ra4m1-compile"]},
            "deadline": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-ra4m1-compile"]},
            "adc": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-ra4m1-compile"]},
            "pwm": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-ra4m1-compile"]},
            "i2c": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-ra4m1-compile"]},
            "spi": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-ra4m1-compile"]},
            "byte_io": {"maturity": "implemented", "evidence": ["arduino-facade-contract", "arduino-ra4m1-compile"]},
            "ble_link": {
              "maturity": "implemented",
              "evidence": ["arduino-ble-unor4-target-build"],
              "limitations": "Exact UNO R4/ArduinoBLE 2.1.0/controller 0.6.0 physical evidence covers GATT write/read/notify, provider disconnect, remount/recovery, and a subscribed BLE link across WiFiS3 DNS/TCP traffic. The complete shared-controller resource price remains unmeasured."
            },
            "wifi_link": {
              "maturity": "implemented",
              "evidence": ["arduino-wifis3-target-build"],
              "limitations": "One exact UNO R4/WiFiS3 0.6.0 workload has zero-disabled, physical association/DNS/TCP/lifecycle, and RA-side/controller-image pricing. Controller-internal runtime resources, BLE coexistence, other firmware versions, and other workloads remain separate."
            }
          }
        }
      }
    },
    "samd21": {
      "arch": "thumbv6m",
      "tier": "core",
      "implementation_root": "core/ports/samd21",
      "compositions": {}
    },
    "avr_nano": {
      "arch": "avr",
      "tier": "core",
      "implementation_root": "core/ports/avr_nano",
      "compositions": {}
    }
  }
}
