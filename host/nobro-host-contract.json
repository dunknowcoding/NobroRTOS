    "app_start_no_softdevice": "0x1000",
    "app_start_s140": "0x26000"
  },
  "phase1_eval": {
    "symbol": "NOBRO_EVAL_REPORT",
    "magic": "0x4E424E31",
    "runner": "project-local phase1 eval runner",
    "warmup_sec": 8,
    "hal": {
      "active_platform_trait": "nobro_hal::PlatformHal",
      "board_trait": "nobro_hal::BoardDesc",
      "platform_feature": "platform-nrf52840",
      "portable_contract_feature": "contract-only"
