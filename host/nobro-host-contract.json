{
  "cdc": { "maintenance_mi": "MI_00", "user_mi": "MI_02" },
  "upload": { "touch_baud": 1200, "lock_per_port": true },
  "debug": { "gdb_incompatible_with": ["deadline_benchmark", "radio_soak"] },
  "ironengine": { "default_baud": 115200, "frame_headers": [170, 85] },
  "ina_monitor": { "jsonl_line_rate_hz_max": 50 },
  "boot_diagnostics": {
    "stage_order": [
      "board_profile",
      "board_package",
      "manifest",
      "adapter_compatibility",
      "admission",
      "runtime"
    ],
    "status_labels": ["missing", "in_progress", "pass", "fail", "corrupt"],
    "diagnostic_code": "u32: stage_code << 24 | status_class << 16 | error_code_low16; status_class pass=0 missing=1 in_progress=2 corrupt=3 fail=4",
    "first_non_pass": true
  },
  "module_tags": {
    "1": "kernel",
    "2": "hal",
    "3": "bus",
    "4": "radio",
    "5": "sensor",
    "6": "actuator",
    "7": "stream",
    "8": "crypto",
    "0x100..0x1FF": "app"
  },
  "capability_bits": {
    "0": "timebase",
    "1": "deadline_timer",
    "2": "event_capture",
    "3": "bus0",
    "4": "bus1",
    "5": "radio",
    "6": "servo_pwm",
    "7": "stream",
    "8": "crypto",
    "9": "sample_pool",
    "10": "host_report"
  },
  "lab": {
    "default_board": "board1",
    "bootloader_policy": "do-not-reflash",
    "app_start_no_softdevice": "0x1000",
    "app_start_s140": "0x26000"
  },
  "phase1_eval": {
    "symbol": "NOBRO_EVAL_REPORT",
    "magic": "0x4E424E31",
    "runner": "project-local phase1 eval runner",
    "warmup_sec": 8,
    "hal": {
      "active_platform_trait": "airon_hal::PlatformHal",
      "board_trait": "airon_hal::BoardDesc",
      "platform_feature": "platform-nrf52840",
      "future_platforms": ["platform-esp32", "platform-rp2040", "platform-stm32"]
    },
    "thresholds": {
      "max_jitter_us": 10,
      "min_deadline_ticks": 150,
      "min_i2c_reads": 10,
      "max_radio_latency_us": 10,
      "min_radio_samples": 16
    },
    "scene_d_golden": {
      "flash_start": "0x1000",
      "pwm_hz": 50,
      "servo_pin": 24,
      "servo_center_us": 1500,
      "twim0_base": "0x40003000"
    }
  },
  "phase2_eval": {
    "symbol": "NOBRO_SAL_EVAL_REPORT",
    "magic": "0x4E424E32",
    "runner": "project-local phase2 eval runner",
    "warmup_sec": 8,
    "sensor_backend": "adapters/sensor-stub",
    "note": "Synthetic IMU fixture via SensorSal stub",
    "thresholds": {
      "min_servo_steps": 20,
      "min_imu_samples": 3,
      "servo_readback_tol_us": 50
    }
  },
  "health_report": {
    "symbol": "NOBRO_HEALTH_REPORT",
    "magic": "0x4E42484C",
    "version": 1,
    "layout": "repr(C) u32 fields; 64-bit timestamps split into lo/hi"
  },
  "event_log_report": {
    "symbol": "NOBRO_EVENT_LOG_REPORT",
    "magic": "0x4E42454C",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum; latest event timestamp split into lo/hi",
    "severity_codes": {
      "0": "trace",
      "1": "info",
      "2": "warn",
      "3": "error",
      "4": "fatal"
    },
    "event_kind_codes": {
      "1": "boot",
      "2": "health",
      "3": "recovery",
      "4": "task_overrun",
      "5": "lease",
      "6": "sample_pool",
      "7": "manifest",
      "8": "host"
    },
    "payload_kind_codes": {
      "0": "none",
      "1": "error",
      "2": "action",
      "3": "counter",
      "4": "pair"
    }
  },
  "module_runtime_report": {
    "symbol": "NOBRO_MODULE_RUNTIME_REPORT",
    "magic": "0x4E424D52",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum; latest module state timestamp split into lo/hi",
    "state_codes": {
      "1": "registered",
      "2": "active",
      "3": "suspended",
      "4": "faulted",
      "5": "recovering",
      "6": "disabled"
    }
  },
  "degrade_application_report": {
    "symbol": "NOBRO_DEGRADE_APPLICATION_REPORT",
    "magic": "0x4E424447",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum; applied timestamp split into lo/hi",
    "reason_codes": {
      "0": "none",
      "1": "flash_budget",
      "2": "ram_budget",
      "3": "pool_budget",
      "4": "module_limit"
    }
  },
  "runtime_report": {
    "symbol": "NOBRO_RUNTIME_REPORT",
    "magic": "0x4E425254",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum; 64-bit alarm due timestamp split into lo/hi",
    "state_codes": {
      "0": "cold_boot",
      "1": "validate_manifest",
      "2": "init_drivers",
      "3": "running",
      "4": "degraded",
      "5": "recovering",
      "6": "halted"
    }
  },
  "board_profile_report": {
    "symbol": "NOBRO_BOARD_PROFILE_REPORT",
    "magic": "0x4E424250",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum; platform and board IDs are FNV-1a 32-bit hashes",
    "status": {
      "missing": "magic/version/checksum are zero",
      "in_progress": "magic/version valid but completed is zero",
      "pass": "checksum valid",
      "corrupt": "bad magic, version, or checksum"
    }
  },
  "board_package_report": {
    "symbol": "NOBRO_BOARD_PACKAGE_REPORT",
    "magic": "0x4E42424B",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum; platform and board IDs are FNV-1a 32-bit hashes",
    "boot_layout_codes": {
      "1": "no_softdevice",
      "2": "softdevice_s140_v6",
      "255": "custom"
    },
    "status": {
      "missing": "magic/version/checksum are zero",
      "in_progress": "magic/version valid but completed is zero",
      "pass": "checksum valid and valid is non-zero",
      "fail": "checksum valid and valid is zero; error_code identifies the class",
      "corrupt": "bad magic, version, or checksum"
    },
    "error_codes": {
      "1": "empty_platform_id",
      "2": "empty_board_id",
      "3": "unaligned_flash_origin",
      "4": "empty_flash_region",
      "5": "empty_ram_region",
      "6": "empty_capacity",
      "7": "duplicate_critical_pin"
    }
  },
  "manifest_report": {
    "symbol": "NOBRO_MANIFEST_REPORT",
    "magic": "0x4E424D46",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum; fingerprint is FNV-1a over module contracts",
    "status": {
      "missing": "magic/version/checksum are zero",
      "in_progress": "magic/version valid but completed is zero",
      "pass": "checksum valid and valid is non-zero",
      "fail": "checksum valid and valid is zero; error_code identifies the class",
      "corrupt": "bad magic, version, or checksum"
    },
    "error_codes": {
      "1": "full",
      "2": "duplicate_module",
      "3": "capability_ownership_conflict",
      "4": "missing_owned_capability",
      "5": "missing_deadline",
      "6": "invalid_deadline",
      "7": "invalid_fault_threshold",
      "8": "empty_memory_budget",
      "9": "module_limit_exceeded",
      "10": "budget_exceeded",
      "11": "user_owns_kernel_capability"
    }
  },
  "adapter_compat_report": {
    "symbol": "NOBRO_ADAPTER_COMPAT_REPORT",
    "magic": "0x4E424143",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum",
    "status": {
      "missing": "magic/version/checksum are zero",
      "in_progress": "magic/version valid but completed is zero",
      "pass": "checksum valid and compatible is non-zero",
      "fail": "checksum valid and compatible is zero; error_code identifies the class",
      "corrupt": "bad magic, version, or checksum"
    },
    "error_codes": {
      "1": "full",
      "2": "duplicate_module",
      "3": "capability_ownership_conflict",
      "4": "module_limit_exceeded",
      "5": "budget_exceeded"
    }
  },
  "admission_report": {
    "symbol": "NOBRO_ADMISSION_REPORT",
    "magic": "0x4E424144",
    "version": 1,
    "layout": "repr(C) u32 fields; checksum is xor of all fields except checksum",
    "status": {
      "missing": "magic/version/checksum are zero",
      "in_progress": "magic/version valid but completed is zero",
      "pass": "checksum valid and admitted is non-zero",
      "fail": "checksum valid and admitted is zero; error_code identifies the class",
      "corrupt": "bad magic, version, or checksum"
    },
    "error_codes": {
      "1": "manifest",
      "2": "startup",
      "3": "quota",
      "4": "capability",
      "5": "missing_startup_node",
      "6": "unknown_startup_node"
    }
  }
}
