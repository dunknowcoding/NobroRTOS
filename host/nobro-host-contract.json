{
  "cdc": {
    "maintenance_mi": "MI_00",
    "user_mi": "MI_02"
  },
  "upload": {
    "touch_baud": 1200,
    "lock_per_port": true
  },
  "debug": {
    "gdb_incompatible_with": [
      "deadline_benchmark",
      "radio_soak"
    ]
  },
  "ironengine": {
    "default_baud": 115200,
    "frame_headers": [
      170,
      85
    ]
  },
  "ina_monitor": {
    "jsonl_line_rate_hz_max": 50
  },
  "boot_diagnostics": {
    "stage_order": [
      "board_profile",
      "board_package",
      "manifest",
      "adapter_compatibility",
      "admission",
      "runtime"
    ],
    "status_labels": [
      "missing",
      "in_progress",
      "pass",
      "fail",
      "corrupt"
    ],
    "diagnostic_code": "u32: stage_code << 24 | status_class << 16 | error_code_low16; status_class pass=0 missing=1 in_progress=2 corrupt=3 fail=4",
    "first_non_pass": true,
    "summary_fields": [
      "diagnostic",
      "slots",
      "pass_count",
      "missing_count",
      "in_progress_count",
      "fail_count",
      "corrupt_count"
    ]
  },
